# =====================================================
# Lublin Explorer – zmienne środowiskowe
# Skopiuj jako .env i uzupełnij własnymi kluczami.
# =====================================================

# Gemini AI – chat przewodnika + generowanie opisów w seedzie
# Wygeneruj na: https://aistudio.google.com/apikey
EXPO_PUBLIC_GROQ_API_KEY=
EXPO_PUBLIC_GROQ_MODEL=
EXPO_PUBLIC_GEMINI_API_KEY=

# Supabase – baza danych + ulubione + statystyki
# Załóż projekt: https://supabase.com/dashboard
# Klucze: Settings → API → URL + anon public
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mapillary – opcjonalne, street-level zdjęcia (obecnie nieużywane w pipeline)
# Rejestracja: https://www.mapillary.com/dashboard/developers
MAPILLARY_TOKEN=

# Google Places API – główne źródło zdjęć atrakcji (Places API legacy)
# Console: https://console.cloud.google.com/apis/credentials
# Włącz: Places API (nie New)
# Restrictions: API restrictions → Places API
GOOGLE_PLACES_API_KEY=
